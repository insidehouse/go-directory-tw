---
import BaseLayout from '../layouts/BaseLayout.astro';
import tournaments from '../data/tournaments.json';

const levels = ['職業', '職業入段', '業餘', '學生', '學員'];
const grouped = levels
  .map((level) => ({
    level,
    items: (tournaments as any[]).filter((t) => t.level === level),
  }))
  .filter((g) => g.items.length > 0);

const levelLabels: Record<string, string> = {
  '職業': '職業賽事',
  '職業入段': '職業入段',
  '業餘': '業餘賽事',
  '學生': '學生賽事',
  '學員': '棋院內部賽',
};

const levelColors: Record<string, string> = {
  '職業': 'bg-yellow-50 text-yellow-800 border-yellow-200',
  '職業入段': 'bg-purple-50 text-purple-800 border-purple-200',
  '業餘': 'bg-blue-50 text-blue-800 border-blue-200',
  '學生': 'bg-green-50 text-green-800 border-green-200',
  '學員': 'bg-gray-50 text-gray-700 border-gray-200',
};
---

<BaseLayout
  title="圍棋比賽賽事"
  description="台灣圍棋比賽資訊整理：職業頭銜賽、業餘段位賽、學生賽事、各棋院內部賽。完整賽事列表與報名資訊。"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:text-primary-600 transition-colors">首頁</a>
      <span class="mx-1">/</span>
      <span class="text-gray-900">比賽賽事</span>
    </nav>

    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">圍棋比賽賽事</h1>
        <p class="mt-1 text-gray-600">台灣圍棋賽事總覽，從職業頭銜賽到棋院內部賽</p>
      </div>
      <p class="text-sm text-gray-400">共 {tournaments.length} 項賽事</p>
    </div>

    <div class="mt-6 bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-sm text-amber-800">
        賽事時間和報名方式可能隨年度調整，建議直接向主辦單位確認最新資訊。
        職業賽事可關注<a href="https://www.haifong.org/" target="_blank" rel="noopener noreferrer" class="font-medium underline hover:text-amber-900">海峰棋院官網</a>。
      </p>
    </div>

    {grouped.map(({ level, items }) => (
      <section class="mt-10">
        <h2 class="text-xl font-semibold text-gray-900">{levelLabels[level] ?? level}</h2>

        <div class="mt-4 space-y-4">
          {items.map((t: any) => (
            <div class={`rounded-lg border p-5 ${levelColors[level] ?? 'bg-white border-gray-200'}`}>
              <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2">
                <h3 class="font-semibold text-gray-900 text-lg">{t.name}</h3>
                <div class="flex items-center gap-2">
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-white/60 text-gray-700">
                    {t.frequency}
                  </span>
                </div>
              </div>
              <p class="mt-2 text-sm text-gray-700">{t.description}</p>
              <div class="mt-2 flex flex-wrap items-center gap-3 text-sm text-gray-600">
                <span>主辦：{t.organizer}</span>
                {t.notes && <span class="text-gray-400">| {t.notes}</span>}
              </div>
              {t.url && (
                <div class="mt-3">
                  <a
                    href={t.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm text-primary-600 hover:text-primary-700 transition-colors inline-flex items-center gap-1"
                  >
                    主辦單位網站
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </a>
                </div>
              )}
            </div>
          ))}
        </div>
      </section>
    ))}

    <section class="mt-12 bg-gray-50 rounded-lg p-6">
      <h2 class="text-lg font-semibold text-gray-900">想參加比賽？</h2>
      <ul class="mt-3 space-y-2 text-sm text-gray-700">
        <li><strong>完全新手</strong>：先到<a href="/schools/" class="text-primary-600 hover:text-primary-700 font-medium">棋院教室</a>學習基礎，參加棋院內部賽累積經驗。</li>
        <li><strong>有級位</strong>：報名全國段位賽，取得段位證書。</li>
        <li><strong>有段位</strong>：挑戰升段賽，或參加各縣市錦標賽。</li>
        <li><strong>志在職業</strong>：加入海峰棋院院生體系，準備職業資格考試。</li>
      </ul>
    </section>
  </div>
</BaseLayout>
