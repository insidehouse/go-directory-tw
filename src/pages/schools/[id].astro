---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchoolCard from '../../components/SchoolCard.astro';
import schools from '../../data/schools.json';
import cityContent from '../../data/city-content.json';

const citySlugMap: Record<string, string> = {
  taipei: '台北',
  newtaipei: '新北',
  taoyuan: '桃園',
  hsinchu: '新竹',
  taichung: '台中',
  tainan: '台南',
  kaohsiung: '高雄',
  keelung: '基隆',
  chiayi: '嘉義',
  hualien: '花蓮',
  yilan: '宜蘭',
  pingtung: '屏東',
  nantou: '南投',
  changhua: '彰化',
};

const allCitySlugs = new Set(Object.keys(citySlugMap));

export function getStaticPaths() {
  const paths: { params: { id: string } }[] = [];

  const citySlugs = [...new Set((schools as any[]).map((s) => s.city_slug))].filter(Boolean);
  for (const slug of citySlugs) {
    paths.push({ params: { id: slug } });
  }

  for (const school of schools as any[]) {
    if (school.slug) {
      paths.push({ params: { id: school.slug } });
    }
  }

  return paths;
}

const { id } = Astro.params;
const isCity = allCitySlugs.has(id!);

const cityName = isCity ? (citySlugMap[id!] ?? id) : '';
const citySchools = isCity ? (schools as any[]).filter((s) => s.city_slug === id) : [];
const school = !isCity ? (schools as any[]).find((s) => s.slug === id) : null;

const cityInfo = isCity ? (cityContent as any)[id!] : null;

const ageLabels: Record<string, string> = {
  children: '兒童',
  teenagers: '青少年',
  adults: '成人',
};

function buildSchoolSchema(s: any) {
  const schema: any = {
    '@context': 'https://schema.org',
    '@type': 'EducationalOrganization',
    name: s.name,
    description: `${s.city}${s.district ?? ''}圍棋教室`,
    areaServed: { '@type': 'City', name: s.city },
  };
  if (s.address) schema.address = { '@type': 'PostalAddress', streetAddress: s.address, addressLocality: s.city, addressCountry: 'TW' };
  if (s.phone) schema.telephone = s.phone;
  if (s.website) schema.url = s.website.startsWith('http') ? s.website : `https://${s.website}`;
  if (s.google_rating) schema.aggregateRating = { '@type': 'AggregateRating', ratingValue: s.google_rating, bestRating: 5, ratingCount: s.google_review_count || 1 };
  if (s.lat && s.lng) schema.geo = { '@type': 'GeoCoordinates', latitude: s.lat, longitude: s.lng };
  if (s.price_range) schema.priceRange = s.price_range;
  return schema;
}

function buildCityListSchema(name: string, items: any[]) {
  return {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: `${name}圍棋教室`,
    numberOfItems: items.length,
    itemListElement: items.map((s, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'EducationalOrganization',
        name: s.name,
        url: `https://go-directory-tw.pages.dev/schools/${s.slug}/`,
        ...(s.address ? { address: { '@type': 'PostalAddress', streetAddress: s.address, addressLocality: s.city, addressCountry: 'TW' } } : {}),
        ...(s.google_rating ? { aggregateRating: { '@type': 'AggregateRating', ratingValue: s.google_rating, bestRating: 5, ratingCount: s.google_review_count || 1 } } : {}),
      },
    })),
  };
}

const schoolSchema = school ? buildSchoolSchema(school) : undefined;
const citySchema = isCity && citySchools.length > 0 ? buildCityListSchema(cityName, citySchools) : undefined;

const sameCitySchools = school
  ? (schools as any[]).filter((s) => s.city_slug === school.city_slug && s.slug !== school.slug).slice(0, 6)
  : [];
const sameChainSchools = school?.chain
  ? (schools as any[]).filter((s) => s.chain === school.chain && s.slug !== school.slug).slice(0, 6)
  : [];
---

{isCity ? (
  <BaseLayout
    title={cityInfo?.title ?? `${cityName}圍棋教室`}
    description={cityInfo?.description?.slice(0, 160) ?? `${cityName}地區圍棋棋院、教室列表。共 ${citySchools.length} 個教學地點，含地址、電話、年齡層等完整資訊。`}
    schema={citySchema}
  >
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
      <nav class="text-sm text-gray-500 mb-4">
        <a href="/" class="hover:text-primary-600 transition-colors">首頁</a>
        <span class="mx-1">/</span>
        <a href="/schools/" class="hover:text-primary-600 transition-colors">棋院教室</a>
        <span class="mx-1">/</span>
        <span class="text-gray-900">{cityName}</span>
      </nav>

      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">{cityName}圍棋教室</h1>
          <p class="mt-1 text-gray-600">{cityName}地區圍棋棋院與教室列表</p>
        </div>
        <p class="text-sm text-gray-400">
          共 {citySchools.length} 個教學地點
        </p>
      </div>

      {cityInfo && (
        <div class="mt-6 bg-white rounded-lg border border-gray-200 p-5">
          <p class="text-sm text-gray-700 leading-relaxed">{cityInfo.description}</p>
          {cityInfo.highlights && (
            <div class="mt-3 flex flex-wrap gap-2">
              {cityInfo.highlights.map((h: string) => (
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-primary-50 text-primary-700">
                  {h}
                </span>
              ))}
            </div>
          )}
        </div>
      )}

      {citySchools.length > 0 ? (
        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {citySchools.map((s: any) => (
            <SchoolCard {...s} />
          ))}
        </div>
      ) : (
        <div class="mt-12 text-center py-16 bg-white rounded-lg border border-gray-200">
          <p class="text-lg font-medium text-gray-900">目前沒有{cityName}的棋院資料</p>
          <p class="mt-2 text-sm text-gray-500">資料持續收集中，敬請期待。</p>
        </div>
      )}

      {cityInfo?.faq && cityInfo.faq.length > 0 && (
        <section class="mt-12">
          <h2 class="text-xl font-semibold text-gray-900">{cityName}學圍棋常見問題</h2>
          <div class="mt-4 space-y-4">
            {cityInfo.faq.map((faq: any) => (
              <details class="group bg-white rounded-lg border border-gray-200 overflow-hidden">
                <summary class="flex items-center justify-between cursor-pointer px-5 py-4 hover:bg-gray-50 transition-colors">
                  <h3 class="text-base font-medium text-gray-900 pr-4">{faq.q}</h3>
                  <svg class="w-5 h-5 text-gray-400 shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="px-5 pb-4 text-sm text-gray-700 leading-relaxed">
                  {faq.a}
                </div>
              </details>
            ))}
          </div>
        </section>
      )}

      <div class="mt-12 bg-gray-50 rounded-lg p-6">
        <h2 class="text-lg font-semibold text-gray-900">開始學棋</h2>
        <p class="mt-2 text-sm text-gray-600">
          不確定怎麼選教室？參考我們的<a href="/guide/" class="text-primary-600 hover:text-primary-700 font-medium">學棋指南</a>了解選教室要點和費用行情，
          或查看<a href="/faq/" class="text-primary-600 hover:text-primary-700 font-medium">常見問題</a>解答你的疑惑。
          也可以透過<a href="/platforms/" class="text-primary-600 hover:text-primary-700 font-medium">線上平台</a>在家練棋。
        </p>
      </div>

      <div class="mt-8 pt-8 border-t border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">其他地區</h2>
        <div class="mt-3 flex flex-wrap gap-2">
          {Object.entries(citySlugMap)
            .filter(([slug]) => slug !== id && (schools as any[]).some((s: any) => s.city_slug === slug))
            .map(([slug, name]) => {
              const count = (schools as any[]).filter((s: any) => s.city_slug === slug).length;
              return (
                <a
                  href={`/schools/${slug}/`}
                  class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-sm bg-gray-100 text-gray-600 hover:bg-primary-50 hover:text-primary-700 transition-colors"
                >
                  {name} <span class="text-gray-400">({count})</span>
                </a>
              );
            })}
        </div>
      </div>
    </div>
  </BaseLayout>
) : school ? (
  <BaseLayout
    title={school.name}
    description={`${school.name} — ${school.city}${school.district ? school.district : ''}圍棋教室。地址、電話、教學資訊一次查詢。`}
    schema={schoolSchema}
  >
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
      <nav class="text-sm text-gray-500 mb-4">
        <a href="/" class="hover:text-primary-600 transition-colors">首頁</a>
        <span class="mx-1">/</span>
        <a href="/schools/" class="hover:text-primary-600 transition-colors">棋院教室</a>
        <span class="mx-1">/</span>
        {school.city_slug && (
          <>
            <a href={`/schools/${school.city_slug}/`} class="hover:text-primary-600 transition-colors">{school.city}</a>
            <span class="mx-1">/</span>
          </>
        )}
        <span class="text-gray-900">{school.name}</span>
      </nav>

      <h1 class="text-3xl font-bold text-gray-900">{school.name}</h1>
      {school.chain && (
        <p class="mt-1 text-gray-500">{school.chain} 體系</p>
      )}

      <div class="mt-6 bg-white rounded-lg border border-gray-200 divide-y divide-gray-100">
        {school.address && (
          <div class="px-5 py-4 flex items-start gap-3">
            <svg class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <div>
              <p class="text-sm font-medium text-gray-500">地址</p>
              <p class="text-gray-900">{school.address}</p>
            </div>
          </div>
        )}

        {school.phone && (
          <div class="px-5 py-4 flex items-start gap-3">
            <svg class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <div>
              <p class="text-sm font-medium text-gray-500">電話</p>
              <a href={`tel:${school.phone.replace(/[\s()-]/g, '')}`} class="text-primary-600 hover:text-primary-700 transition-colors">
                {school.phone}
              </a>
            </div>
          </div>
        )}

        <div class="px-5 py-4 flex items-start gap-3">
          <svg class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <div>
            <p class="text-sm font-medium text-gray-500">適合年齡</p>
            <div class="mt-1 flex flex-wrap gap-1.5">
              {(school.age_groups ?? []).map((age: string) => (
                <span class="inline-flex items-center px-2.5 py-1 rounded text-sm font-medium bg-gray-100 text-gray-700">
                  {ageLabels[age] ?? age}
                </span>
              ))}
            </div>
          </div>
        </div>

        {school.price_public && school.price_range && (
          <div class="px-5 py-4 flex items-start gap-3">
            <svg class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <p class="text-sm font-medium text-gray-500">學費資訊</p>
              <p class="text-gray-900">{school.price_range}</p>
            </div>
          </div>
        )}

        {school.google_rating && (
          <div class="px-5 py-4 flex items-start gap-3">
            <svg class="w-5 h-5 text-yellow-400 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            <div>
              <p class="text-sm font-medium text-gray-500">Google 評分</p>
              <p class="text-gray-900">{school.google_rating} / 5{school.google_review_count ? ` (${school.google_review_count} 則評論)` : ''}</p>
            </div>
          </div>
        )}
      </div>

      {school.notes && (
        <div class="mt-6 bg-gray-50 rounded-lg p-5">
          <p class="text-sm font-medium text-gray-500 mb-1">備註</p>
          <p class="text-gray-700">{school.notes}</p>
        </div>
      )}

      <div class="mt-6 flex flex-wrap gap-3">
        {school.website && (
          <a
            href={school.website.startsWith('http') ? school.website : `https://${school.website}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-primary-600 text-white text-sm font-medium hover:bg-primary-700 transition-colors"
          >
            官方網站
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        )}
        {school.facebook_url && (
          <a
            href={school.facebook_url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors"
          >
            Facebook 粉專
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        )}
        {school.google_maps_url && (
          <a
            href={school.google_maps_url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-white text-gray-700 text-sm font-medium border border-gray-300 hover:bg-gray-50 transition-colors"
          >
            Google Maps
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        )}
      </div>

      {sameChainSchools.length > 0 && (
        <div class="mt-10 pt-8 border-t border-gray-200">
          <h2 class="text-lg font-semibold text-gray-900">{school.chain}其他分校</h2>
          <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
            {sameChainSchools.map((s: any) => (
              <a
                href={`/schools/${s.slug}/`}
                class="flex items-center justify-between px-4 py-3 bg-white rounded-lg border border-gray-200 hover:border-primary-300 hover:bg-primary-50 transition-colors"
              >
                <div>
                  <p class="text-sm font-medium text-gray-900">{s.name}</p>
                  <p class="text-xs text-gray-500">{s.city}{s.district ?? ''}</p>
                </div>
                {s.google_rating && (
                  <span class="text-xs text-gray-500">{s.google_rating}</span>
                )}
              </a>
            ))}
          </div>
        </div>
      )}

      {sameCitySchools.length > 0 && (
        <div class="mt-10 pt-8 border-t border-gray-200">
          <h2 class="text-lg font-semibold text-gray-900">{school.city}其他圍棋教室</h2>
          <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
            {sameCitySchools.map((s: any) => (
              <a
                href={`/schools/${s.slug}/`}
                class="flex items-center justify-between px-4 py-3 bg-white rounded-lg border border-gray-200 hover:border-primary-300 hover:bg-primary-50 transition-colors"
              >
                <div>
                  <p class="text-sm font-medium text-gray-900">{s.name}</p>
                  <p class="text-xs text-gray-500">{s.district ?? ''}{s.chain ? ` · ${s.chain}` : ''}</p>
                </div>
                {s.google_rating && (
                  <span class="text-xs text-gray-500">{s.google_rating}</span>
                )}
              </a>
            ))}
          </div>
          <div class="mt-4">
            <a href={`/schools/${school.city_slug}/`} class="text-sm text-primary-600 hover:text-primary-700 font-medium">
              查看{school.city}全部教室 &rarr;
            </a>
          </div>
        </div>
      )}

      <div class="mt-10 bg-gray-50 rounded-lg p-6">
        <h2 class="text-lg font-semibold text-gray-900">不確定怎麼選？</h2>
        <p class="mt-2 text-sm text-gray-600">
          參考<a href="/guide/" class="text-primary-600 hover:text-primary-700 font-medium">學棋指南</a>了解選教室的要點，
          或到<a href="/faq/" class="text-primary-600 hover:text-primary-700 font-medium">常見問題</a>看看其他家長常問的問題。
        </p>
      </div>

      <div class="mt-8 text-xs text-gray-400">
        <p>資料來源：{(school.data_sources ?? []).join('、') || '公開資料'}</p>
        <p>最後驗證：{school.last_verified ?? '未知'}</p>
      </div>
    </div>
  </BaseLayout>
) : (
  <BaseLayout title="找不到頁面">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16 text-center">
      <h1 class="text-2xl font-bold text-gray-900">找不到頁面</h1>
      <p class="mt-2 text-gray-600">
        <a href="/schools/" class="text-primary-600 hover:text-primary-700">返回棋院列表</a>
      </p>
    </div>
  </BaseLayout>
)}
