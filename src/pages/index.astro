---
import BaseLayout from '../layouts/BaseLayout.astro';
import schools from '../data/schools.json';

const totalLocations = schools.length;
const totalCities = new Set((schools as any[]).map((s) => s.city)).size;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '台灣圍棋目錄',
  url: 'https://go-directory-tw.pages.dev',
  description: '台灣圍棋棋院、教室、比賽、線上平台完整目錄。',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://go-directory-tw.pages.dev/schools/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout title="首頁" description="台灣圍棋棋院、教室、比賽、線上平台完整目錄。幫助家長和棋友快速找到適合的圍棋學習資源。" schema={websiteSchema}>
  <section class="bg-gradient-to-b from-primary-50 to-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
      <div class="text-center">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 tracking-tight">
          找到適合的<span class="text-primary-600">圍棋教室</span>
        </h1>
        <p class="mt-4 text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto">
          台灣最完整的圍棋資源目錄。收錄 {totalCities} 個縣市、{totalLocations} 個教學地點，一站查詢。
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
          <a
            href="/schools/"
            class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3 rounded-lg bg-primary-600 text-white font-medium hover:bg-primary-700 transition-colors shadow-sm"
          >
            瀏覽棋院教室
          </a>
          <a
            href="/about/"
            class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3 rounded-lg bg-white text-gray-700 font-medium hover:bg-gray-50 transition-colors border border-gray-300"
          >
            關於本站
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mx-auto">
          <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
        <h2 class="mt-4 text-lg font-semibold text-gray-900">棋院教室</h2>
        <p class="mt-2 text-sm text-gray-500">
          收錄全台 {totalLocations} 個教學地點，依縣市、年齡層快速篩選，找到離你最近的棋院。
        </p>
        <a href="/schools/" class="mt-3 inline-block text-sm text-primary-600 hover:text-primary-700 font-medium">
          查看全部 &rarr;
        </a>
      </div>

      <div class="text-center">
        <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mx-auto">
          <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <h2 class="mt-4 text-lg font-semibold text-gray-900">比賽賽事</h2>
        <p class="mt-2 text-sm text-gray-500">
          台灣圍棋比賽日曆，包含升段賽、公開賽等各級賽事資訊。
        </p>
        <a href="/tournaments/" class="mt-3 inline-block text-sm text-primary-600 hover:text-primary-700 font-medium">
          查看全部 &rarr;
        </a>
      </div>

      <div class="text-center">
        <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mx-auto">
          <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
          </svg>
        </div>
        <h2 class="mt-4 text-lg font-semibold text-gray-900">線上平台</h2>
        <p class="mt-2 text-sm text-gray-500">
          線上對弈、學習、AI 分析平台整理，隨時隨地精進棋力。
        </p>
        <a href="/platforms/" class="mt-3 inline-block text-sm text-primary-600 hover:text-primary-700 font-medium">
          查看全部 &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
