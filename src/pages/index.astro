---
import BaseLayout from '../layouts/BaseLayout.astro';
import schools from '../data/schools.json';

const totalLocations = schools.length;
const totalCities = new Set((schools as any[]).map((s) => s.city)).size;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '台灣圍棋目錄',
  url: 'https://go-directory-tw.pages.dev',
  description: '台灣圍棋棋院、教室、比賽、線上平台完整目錄。',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://go-directory-tw.pages.dev/schools/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout title="首頁" description="台灣圍棋棋院、教室、比賽、線上平台完整目錄。幫助家長和棋友快速找到適合的圍棋學習資源。" schema={websiteSchema}>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-kaya-100/40">
    <div class="absolute inset-0 go-grid-bg"></div>

    <!-- Decorative floating stones -->
    <div class="float-stone stone-black w-10 h-10 top-[18%] left-[7%] opacity-50 animate-fade-in animate-delay-4 hidden sm:block" aria-hidden="true"></div>
    <div class="float-stone stone-white w-7 h-7 top-[28%] right-[11%] opacity-40 animate-fade-in animate-delay-6 hidden sm:block" aria-hidden="true"></div>
    <div class="float-stone stone-black w-5 h-5 bottom-[22%] right-[16%] opacity-30 animate-fade-in animate-delay-5 hidden lg:block" aria-hidden="true"></div>
    <div class="float-stone stone-white w-11 h-11 bottom-[18%] left-[5%] opacity-25 animate-fade-in animate-delay-8 hidden sm:block" aria-hidden="true"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-20 sm:py-28 lg:py-32">
      <div class="text-center">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-ink-950 tracking-tight font-display leading-[1.15] animate-fade-in-up" style="text-wrap: balance;">
          找到適合的<span class="text-kaya-600">圍棋教室</span>
        </h1>
        <p class="mt-5 text-lg sm:text-xl text-ink-500 max-w-xl mx-auto opacity-0 animate-fade-in-up animate-delay-2">
          台灣最完整的圍棋資源目錄
        </p>

        <!-- Stats -->
        <div class="mt-10 inline-flex items-center gap-6 sm:gap-10 opacity-0 animate-fade-in-up animate-delay-3">
          <div class="text-center">
            <p class="text-2xl sm:text-3xl font-bold text-ink-900 font-display">{totalCities}</p>
            <p class="text-xs sm:text-sm text-ink-400 mt-0.5">個縣市</p>
          </div>
          <div class="w-px h-8 bg-kaya-300/50"></div>
          <div class="text-center">
            <p class="text-2xl sm:text-3xl font-bold text-ink-900 font-display">{totalLocations}</p>
            <p class="text-xs sm:text-sm text-ink-400 mt-0.5">個教學地點</p>
          </div>
          <div class="w-px h-8 bg-kaya-300/50"></div>
          <div class="text-center">
            <p class="text-2xl sm:text-3xl font-bold text-ink-900 font-display">10</p>
            <p class="text-xs sm:text-sm text-ink-400 mt-0.5">線上平台</p>
          </div>
        </div>

        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3 opacity-0 animate-fade-in-up animate-delay-4">
          <a
            href="/schools/"
            class="w-full sm:w-auto inline-flex items-center justify-center px-7 py-3.5 rounded-lg bg-ink-900 text-kaya-50 font-medium hover:bg-ink-800 transition-colors shadow-sm"
          >
            瀏覽棋院教室
          </a>
          <a
            href="/guide/"
            class="w-full sm:w-auto inline-flex items-center justify-center px-7 py-3.5 rounded-lg bg-white text-ink-700 font-medium hover:bg-kaya-100 transition-colors border border-kaya-200"
          >
            學棋指南
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <!-- 棋院教室 — black stone icon -->
      <a href="/schools/" class="group bg-white rounded-xl border border-kaya-200/60 p-6 hover:border-kaya-300 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
        <div class="w-12 h-12 rounded-full stone-black flex items-center justify-center">
          <div class="w-3 h-3 rounded-full bg-white/10 -mt-1 -ml-1"></div>
        </div>
        <h2 class="mt-5 text-xl font-bold text-ink-900 group-hover:text-kaya-700 transition-colors font-display">棋院教室</h2>
        <p class="mt-2 text-sm text-ink-500 leading-relaxed">
          收錄全台 {totalLocations} 個教學地點，依縣市、年齡層快速篩選，找到離你最近的棋院。
        </p>
        <span class="mt-4 inline-flex items-center text-sm font-medium text-gold-600 group-hover:text-gold-700">
          查看全部
          <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </span>
      </a>

      <!-- 比賽賽事 — black & white stones -->
      <a href="/tournaments/" class="group bg-white rounded-xl border border-kaya-200/60 p-6 hover:border-kaya-300 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
        <div class="w-12 h-12 rounded-full bg-kaya-100 flex items-center justify-center">
          <svg class="w-8 h-8" viewBox="0 0 32 32" fill="none">
            <circle cx="12" cy="16" r="6" fill="url(#feat-bs)" />
            <circle cx="20" cy="16" r="6" fill="url(#feat-ws)" stroke="#d3b888" stroke-width="0.5" />
            <defs>
              <radialGradient id="feat-bs" cx="0.38" cy="0.35">
                <stop offset="0%" stop-color="#555" />
                <stop offset="100%" stop-color="#1a1816" />
              </radialGradient>
              <radialGradient id="feat-ws" cx="0.38" cy="0.35">
                <stop offset="0%" stop-color="#fff" />
                <stop offset="100%" stop-color="#e6ddd0" />
              </radialGradient>
            </defs>
          </svg>
        </div>
        <h2 class="mt-5 text-xl font-bold text-ink-900 group-hover:text-kaya-700 transition-colors font-display">比賽賽事</h2>
        <p class="mt-2 text-sm text-ink-500 leading-relaxed">
          台灣圍棋比賽日曆，包含升段賽、公開賽等各級賽事資訊。
        </p>
        <span class="mt-4 inline-flex items-center text-sm font-medium text-gold-600 group-hover:text-gold-700">
          查看全部
          <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </span>
      </a>

      <!-- 線上平台 — mini board icon -->
      <a href="/platforms/" class="group bg-white rounded-xl border border-kaya-200/60 p-6 hover:border-kaya-300 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
        <div class="w-12 h-12 rounded-lg bg-kaya-100 flex items-center justify-center">
          <svg class="w-7 h-7" viewBox="0 0 28 28" fill="none">
            <rect x="2" y="2" width="24" height="24" rx="2" stroke="#77542e" stroke-width="1.5" />
            <line x1="2" y1="10" x2="26" y2="10" stroke="#d3b888" stroke-width="0.75" />
            <line x1="2" y1="18" x2="26" y2="18" stroke="#d3b888" stroke-width="0.75" />
            <line x1="10" y1="2" x2="10" y2="26" stroke="#d3b888" stroke-width="0.75" />
            <line x1="18" y1="2" x2="18" y2="26" stroke="#d3b888" stroke-width="0.75" />
            <circle cx="14" cy="14" r="2.5" fill="#e6ddd0" stroke="#b9b4ae" stroke-width="0.5" />
          </svg>
        </div>
        <h2 class="mt-5 text-xl font-bold text-ink-900 group-hover:text-kaya-700 transition-colors font-display">線上平台</h2>
        <p class="mt-2 text-sm text-ink-500 leading-relaxed">
          線上對弈、學習、AI 分析平台整理，隨時隨地精進棋力。
        </p>
        <span class="mt-4 inline-flex items-center text-sm font-medium text-gold-600 group-hover:text-gold-700">
          查看全部
          <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </span>
      </a>
    </div>
  </section>
</BaseLayout>
