---
interface Props {
  name: string;
  chain?: string;
  city: string;
  city_slug?: string;
  district?: string;
  address?: string;
  phone?: string;
  website?: string;
  facebook_url?: string;
  google_rating?: number | null;
  google_review_count?: number;
  google_maps_url?: string;
  age_groups?: string[];
  price_public?: boolean;
  price_range?: string | null;
  slug?: string;
}

const {
  name,
  chain,
  city,
  district,
  address,
  phone,
  website,
  facebook_url,
  google_rating,
  google_review_count,
  google_maps_url,
  age_groups = [],
  price_public = false,
  price_range,
  slug,
} = Astro.props;

const ageLabels: Record<string, string> = {
  children: '兒童',
  teenagers: '青少年',
  adults: '成人',
};
---

<article class="bg-white rounded-lg border border-gray-200 p-5 hover:shadow-md transition-shadow">
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <h3 class="text-lg font-semibold text-gray-900 truncate">
        {slug ? (
          <a href={`/schools/${slug}/`} class="hover:text-primary-600 transition-colors">
            {name}
          </a>
        ) : (
          name
        )}
      </h3>
      {chain && (
        <p class="text-sm text-gray-500 mt-0.5">{chain} 體系</p>
      )}
    </div>

    {google_rating && (
      <div class="flex items-center gap-1 shrink-0">
        <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        <span class="text-sm font-medium text-gray-700">{google_rating}</span>
        {google_review_count ? (
          <span class="text-xs text-gray-400">({google_review_count})</span>
        ) : null}
      </div>
    )}
  </div>

  <div class="mt-3 space-y-1.5">
    {address && (
      <p class="text-sm text-gray-600 flex items-start gap-2">
        <svg class="w-4 h-4 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span>{address}</span>
      </p>
    )}

    {phone && (
      <p class="text-sm text-gray-600 flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <a href={`tel:${phone.replace(/[\s()-]/g, '')}`} class="hover:text-primary-600 transition-colors">
          {phone}
        </a>
      </p>
    )}
  </div>

  <div class="mt-3 flex flex-wrap gap-1.5">
    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-primary-50 text-primary-700">
      {city}{district ? ` ${district}` : ''}
    </span>

    {age_groups.map((age) => (
      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">
        {ageLabels[age] ?? age}
      </span>
    ))}

    {price_public && price_range && (
      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-50 text-green-700">
        {price_range}
      </span>
    )}
  </div>

  <div class="mt-3 pt-3 border-t border-gray-100 flex flex-wrap gap-3">
    {website && (
      <a
        href={website.startsWith('http') ? website : `https://${website}`}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-primary-600 hover:text-primary-700 transition-colors inline-flex items-center gap-1"
      >
        官方網站
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    )}
    {facebook_url && (
      <a
        href={facebook_url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-blue-600 hover:text-blue-700 transition-colors inline-flex items-center gap-1"
      >
        Facebook
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    )}
    {google_maps_url && (
      <a
        href={google_maps_url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-green-600 hover:text-green-700 transition-colors inline-flex items-center gap-1"
      >
        Google Maps
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    )}
  </div>
</article>
